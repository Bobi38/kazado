model core_calendar {
  id                  String                       @id @default(cuid())
  name                String
  nb_home             Int
  validator           Boolean
  invitationSentUser  core_user_invit[]            @relation("IdCalendar")
  userCalendar        core_calendar_user[]         @relation("IdCalendar")
  admCalendar         core_calendar_admin[]        @relation("IdCalendar")
  validatorCalendar   core_calendar_validator[]    @relation("IdCalendar")
  reservationCalendat core_reservation[]           @relation("IdCalendar")
  relationCalHome     core_relation_CalendarHome[] @relation("IdCalendar")
  HomeCalendar        core_home[]                  @relation("IdCalendar")
}

model core_home {
  id            Int                          @id @default(autoincrement())
  nb_people     Int
  nb_bedroom    Int
  adress        String?
  name          String
  isToDo        Boolean                      @default(false)
  id_calendar   core_calendar                @relation("IdCalendar", fields: [calendarId], references: [id])
  calendarId    String
  idReservation core_reservation[]           @relation("IdHome")
  calRelation   core_relation_CalendarHome[] @relation("IdHome")
  toDoTasks     core_todo[]                  @relation("IdHome")
}

model core_todo {
  id      Int       @id @default(autoincrement())
  id_home core_home @relation("IdHome", fields: [homeId], references: [id])
  homeId  Int
  task    String
  status  Boolean   @default(false)
}

model core_calendar_user {
  id          Int           @id @default(autoincrement())
  id_calendar core_calendar @relation("IdCalendar", fields: [calendarId], references: [id])
  id_user     core_user     @relation("UserId", fields: [userId], references: [id])
  status      Boolean
  calendarId  String
  userId      Int
}

model core_calendar_admin {
  id          Int           @id @default(autoincrement())
  id_calendar core_calendar @relation("IdCalendar", fields: [calendarId], references: [id])
  id_user     core_user     @relation("UserAdmin", fields: [idadm], references: [id])
  calendarId  String
  idadm       Int
}

model core_calendar_validator {
  id          Int           @id @default(autoincrement())
  id_calendar core_calendar @relation("IdCalendar", fields: [calendarId], references: [id])
  id_user     core_user     @relation("UserValidator", fields: [idvalidator], references: [id])
  calendarId  String
  idvalidator Int
}

model core_relation_CalendarHome {
  id          Int           @id @default(autoincrement())
  id_calendar core_calendar @relation("IdCalendar", fields: [calendarId], references: [id])
  id_home     core_home     @relation("IdHome", fields: [homeId], references: [id])
  calendarId  String
  homeId      Int
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model core_reservation {
  id          Int                     @id @default(autoincrement())
  id_user     core_user               @relation("UserIdResa", fields: [userId], references: [id])
  id_calendar core_calendar           @relation("IdCalendar", fields: [calendarId], references: [id])
  id_home     core_home               @relation("IdHome", fields: [homeId], references: [id])
  name        String
  Date_start  DateTime?
  Date_end    DateTime?
  status      Boolean                 @default(false)
  nb_adult    Int
  nb_children Int
  note        String
  userId      Int
  calendarId  String
  homeId      Int
  allUser     core_reservation_user[] @relation("ResaId")
}

model core_reservation_user {
  id      Int              @id @default(autoincrement())
  id_resa core_reservation @relation("ResaId", fields: [resaId], references: [id])
  id_user core_user        @relation("UserId", fields: [userId], references: [id])
  resaId  Int
  userId  Int
}

model core_user {
  id                  Int                       @id @default(autoincrement())
  email               String                    @unique
  name                String?
  lastname            String?
  pseudo              String                    @unique
  password            String
  invitationsSent     core_user_invit[]         @relation("UserHost")
  invitationsReceived core_user_invit[]         @relation("UserGuest")
  userAdm             core_calendar_admin[]     @relation("UserAdmin")
  UserId              core_calendar_user[]      @relation("UserId")
  userValidator       core_calendar_validator[] @relation("UserValidator")
  reservationUser     core_reservation[]        @relation("UserIdResa")
  inResaUser          core_reservation_user[]   @relation("UserId")
}

model core_user_invit {
  id            Int           @id @default(autoincrement())
  id_user_host  core_user     @relation("UserHost", fields: [hostId], references: [id])
  id_user_guest core_user     @relation("UserGuest", fields: [guestId], references: [id])
  id_calendar   core_calendar @relation("IdCalendar", fields: [calendarId], references: [id])
  hostId        Int
  guestId       Int
  calendarId    String
}
